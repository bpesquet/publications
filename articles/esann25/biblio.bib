
@article{flemingMetacognitionConfidenceReview,
	title = {Metacognition and {Confidence}: {A} {Review} and {Synthesis}},
	volume = {75},
	issn = {0066-4308, 1545-2085},
	shorttitle = {Metacognition and {Confidence}},
	url = {https://www.annualreviews.org/content/journals/10.1146/annurev-psych-022423-032425},
	doi = {10.1146/annurev-psych-022423-032425},
	abstract = {Determining the psychological, computational, and neural bases of confidence and uncertainty holds promise for understanding foundational aspects of human metacognition. While a neuroscience of confidence has focused on the mechanisms underpinning subpersonal phenomena such as representations of uncertainty in the visual or motor system, metacognition research has been concerned with personal-level beliefs and knowledge about self-performance. I provide a road map for bridging this divide by focusing on a particular class of confidence computation: propositional confidence in one\&apos;s own (hypothetical) decisions or actions. Propositional confidence is informed by the observer\&apos;s models of the world and their cognitive system, which may be more or less accurate—thus explaining why metacognitive judgments are inferential and sometimes diverge from task performance. Disparate findings on the neural basis of uncertainty and performance monitoring are integrated into a common framework, and a new understanding of the locus of action of metacognitive interventions is developed.},
	language = {fr},
	number = {Volume 75, 2024},
	urldate = {2024-05-31},
	journal = {Annual Review of Psychology},
	author = {Fleming, Stephen M.},
	month = jan,
	year = {2024},
	note = {Publisher: Annual Reviews},
	pages = {241--268},
	file = {Snapshot:/Users/falex/Zotero/storage/TD28XG2L/annurev-psych-022423-032425.html:text/html;Version soumise:/Users/falex/Zotero/storage/PRMQIAV3/Fleming - 2024 - Metacognition and Confidence A Review and Synthes.pdf:application/pdf},
}

