  abstract = {Temporally extended actions (e.g., macro actions) have proven very useful in speeding up learning, ensuring robustness and building prior knowledge into AI systems. The options framework (Precup, 2000; Sutton, Precup \& Singh, 1999) provides a natural way of incorporating such actions into reinforcement learning systems, but leaves open the issue of how good options might be identified. In this paper, we empirically explore a simple approach to creating options. The underlying assumption is that the agent will be asked to perform different goal-achievement tasks in an environment that is otherwise the same over time. Our approach is based on the intuition that ``bottleneck'' states, i.e. states that are frequently visited on system trajectories, could prove to be useful subgoals (e.g. McGovern \& Barto, 2001; Iba, 1989).},
  isbn = {978-3-540-43941-7 978-3-540-45622-3},
  langid = {english},
  file = {/Users/baptiste/Zotero/storage/U6G2I8GS/Stolle et Precup - 2002 - Learning Options in Reinforcement Learning.pdf}
}

